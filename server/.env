PORT=5000

# For local development: set to your Vite dev server URL
# For production: set to your Vercel frontend URL (or comma-separated list)
# Example: CLIENT_URL=https://medivault.vercel.app
CLIENT_URL=http://localhost:5173

# Firebase Admin credentials
# OPTION 1 (Recommended for Render): Paste the entire service account JSON as a single line
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# OPTION 2: Path to the service account JSON file (local dev)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
